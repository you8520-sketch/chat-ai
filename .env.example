# OpenRouter API 키 (채팅·백그라운드 기억·비전 등 전체 LLM)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# 로컬 개발: 캐릭터 노출 이미지 검수 건너뛰기 (1|true|yes)
# SKIP_ASSET_MODERATION=1
# 백그라운드 비전 — 이미지 검열·에셋 태그 (DeepSeek V3 vision 미지원)
# BACKGROUND_VISION_MODEL=google/gemini-2.0-flash-001
# ASSET_VISION_MODEL=google/gemini-2.0-flash-001
# 공개 캐릭터 노출 이미지 검수 (미설정 시 BACKGROUND_VISION_MODEL, 실패 시 2.5 Flash)
# ASSET_MODERATION_MODEL=google/gemini-2.0-flash-001
# ASSET_MODERATION_MODEL_FALLBACK=google/gemini-2.5-flash

# OpenRouter Claude Opus (claude-3-opus는 OpenRouter endpoint 없음 → 4.5 사용)
OPENROUTER_MODEL=anthropic/claude-opus-4.5
# OpenRouter 권장 헤더 (선택)
# OPENROUTER_HTTP_REFERER=http://localhost:3000
# OPENROUTER_APP_TITLE=PlayAI
# OpenRouter 과금: dev 고정 20P는 fixed
# OPENROUTER_BILLING_MODE=fixed
# Claude Opus — 출력 1자당 0.142P (마진·원가 블렌드 없음) · UI 기본 숨김
# OPENROUTER_OPUS_USER_SELECTABLE=1
# OPENROUTER_OPUS_POINTS_PER_CHAR=0.142
# Qwen 3.7 — 출력 1토큰당 0.062P · 면제 시 최소 50P
# OPENROUTER_QWEN_POINTS_PER_OUTPUT_TOKEN=0.062
# Gemini 2.5 Pro — 출력 1토큰당 0.065P · 면제 시 최소 50P
# OPENROUTER_GEMINI_25_POINTS_PER_OUTPUT_TOKEN=0.065
# Gemini 3.1 Pro — 출력 1토큰당 0.075P · 면제 시 최소 65P
# OPENROUTER_GEMINI_31_POINTS_PER_OUTPUT_TOKEN=0.075
# Gemini Pro RP — provider.google.thinking type none (Pro 모델 직접 호출, Flash 우회 없음)
# DeepSeek V4 — 출력 1토큰당 0.022P · 면제 시 최소 20P
# OPENROUTER_DEEPSEEK_POINTS_PER_OUTPUT_TOKEN=0.022
# 입력 8,000토큰 초과분 — 1,000토큰당 1.5P 추가 (전 OpenRouter 모델)
# OPENROUTER_INPUT_SURCHARGE_PER_1000_TOKENS=1.5
# cache_read_tokens → 입력 단가 10% (90% 할인), cache_write → 125%

# 백그라운드 기억·요약·상태창·번역 등 — OpenRouter DeepSeek V3 (일반 bg 12k tok)
BACKGROUND_MEMORY_MODEL=deepseek/deepseek-chat-v3-0324
# 6턴 기억 요약 전용 입력 상한 (기본 48,000 tok — 12k는 system 지시·대화 잘림 유발)
# BACKGROUND_MEMORY_EXTRACT_MAX_INPUT_TOKENS=48000
# 캐릭터 설정 KO→EN 번역 (미설정 시 BACKGROUND_MEMORY_MODEL)
# PROMPT_TRANSLATION_MODEL=deepseek/deepseek-chat-v3-0324
# PROMPT_TRANSLATION_FALLBACK_MODELS=deepseek/deepseek-chat-v3-0324

# 실제 API 원가 USD→KRW: daily_kst(KST 자정 고정, 기본) | realtime(1h 캐시)
# EXCHANGE_RATE_MODE=daily_kst
# EXCHANGE_RATE_FALLBACK_KRW=1500

# Dry-run — 실제 OpenRouter HTTP 차단 (1|true|yes). debug_payload.json에 payload 기록
# MOCK_MODE=1
# MOCK_FINISH_REASON=STOP
# MOCK_FINISH_REASON=MAX_TOKENS

# 장기기억 시스템 전체 비활성 (0|false|no|off)
# MEMORY_FEATURE_ENABLED=0

# example_dialog 비어 있을 때 공간·소리·거리 platform few-shot 주입 (기본 OFF — 1|true|yes|on)
# NARRATION_FEWSHOT_FALLBACK_ENABLED=1

# 구글 간편 로그인
# 승인된 리디렉션 URI (Google Console): http://localhost:8092/api/auth/google/callback
# 브라우저는 localhost로 접속 — 0.0.0.0은 Google OAuth에서 거부됩니다.
# NEXTAUTH_URL=http://localhost:8092
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PortOne V2 (포인트 충전) — 클로즈베타: 결제 비활성화
NEXT_PUBLIC_PORTONE_STORE_ID=iamporttest_3
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=channel-key-a55bc529-05f2-47f4-b5a2-210456320fcb
PORTONE_CHARGE_ENABLED=0
NEXT_PUBLIC_PAYMENTS_ENABLED=0
# 클로즈베타: 성인인증 생략 (1|true|yes). 미설정 시 PORTONE_CHARGE_ENABLED=0이면 자동 생략
# SKIP_ADULT_VERIFICATION=1

# Railway persistent SQLite — mount volume at /data
# DATA_DIR=/data
# Production runtime must use a persistent DATA_DIR (or mounted /data) so SQLite sessions survive deploys/restarts.

# Stable server-side secrets (generate once and keep fixed in production)
# SESSION_SECRET=replace-with-32-plus-random-bytes
# WITHDRAWAL_ENCRYPTION_KEY=replace-with-32-plus-random-bytes

# OPENROUTER_HTTP_REFERER=https://your-app.up.railway.app
# 결제 조회·검증 — 포트원 콘솔 V2 API Secret (서버 전용)
# PORTONE_API_SECRET=
# PORTONE_CHARGE_ENABLED=1

# 관리자 — 이메일 화이트리스트(쉼표 구분) 또는 DB users.is_admin=1
# npx tsx scripts/set-admin.ts --email you@example.com
# ADMIN_EMAILS=you@example.com,ops@example.com
# 정산 CSV export API — x-admin-secret 헤더 (선택)
# ADMIN_EXPORT_SECRET=
